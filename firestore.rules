rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      // تحديث كامل للأدمن، أو تحديث لحقل orderCount بس (بيتحصّل تلقائي عند
      // إرسال أي طلب حقيقي من عميل مش مسجّل دخول — شوف saveOrder في firestore.ts).
      // القيمة لازم تزيد فقط وبمقدار محدود (نفس حد عدد أصناف الطلب تحت) —
      // بيمنع كتابة رقم عشوائي كبير لعدّاد المبيعات على صنف مش حقيقي.
      allow update: if request.auth != null
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(["orderCount"])
            && request.resource.data.orderCount is int
            && request.resource.data.orderCount > resource.data.get("orderCount", 0)
            && request.resource.data.orderCount <= resource.data.get("orderCount", 0) + 300);
    }
    match /branches/{branchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /deliveryZones/{zoneId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /paymentMethods/{methodId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /suppliers/{supplierId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posterLinks/{linkId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // سجل الطلبات: أي زبون (من غير تسجيل دخول) يقدر يبعت طلب، لكن قراءة
    // السجل (بيانات عملاء) مقصورة على الأدمن بس — عكس باقي المجموعات فوق.
    // شكل البيانات المسموح بيه على create مقصود يكون ضيق (مش مجرد "أي حاجة")
    // عشان يصعّب حقن مستندات مزيّفة/ضخمة — مش بديل عن rate limiting حقيقي
    // (محتاج Cloud Functions على خطة Blaze أو Firebase App Check).
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.createdAt == request.time
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 300
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.savings is number
        && request.resource.data.orderType in ["pickup", "delivery"]
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 0
        && request.resource.data.customerName.size() <= 200
        && request.resource.data.customerPhone is string
        && request.resource.data.customerPhone.size() > 0
        && request.resource.data.customerPhone.size() <= 50
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 2000;
      allow update, delete: if request.auth != null;
    }
    // النسخ الاحتياطي: مقصور على الأدمن بالكامل (قراءة وكتابة) — مفيش داعي
    // يكون عام زي باقي المجموعات، ومسار الـ cron بيسجّل دخول كأدمن قبل الكتابة.
    match /backups/{backupId} {
      allow read, write: if request.auth != null;
    }
    // اشتراكات إشعارات الخصومات: أي زبون (من غير تسجيل دخول) يقدر يسجّل
    // اشتراكه (زي orders)، لكن قراءتها (عشان إرسال الإشعارات) وحذفها مقصورة
    // على الأدمن بس.
    match /pushSubscriptions/{subId} {
      allow read, delete: if request.auth != null;
      allow create: if request.resource.data.createdAt == request.time
        && request.resource.data.endpoint is string
        && request.resource.data.endpoint.size() > 0
        && request.resource.data.endpoint.size() <= 1000
        && request.resource.data.keys is map
        && request.resource.data.keys.p256dh is string
        && request.resource.data.keys.p256dh.size() <= 300
        && request.resource.data.keys.auth is string
        && request.resource.data.keys.auth.size() <= 300;
    }
  }
}

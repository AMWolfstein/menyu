rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /items/{itemId} {
      allow read: if true;
      allow create, delete: if request.auth != null;
      // تحديث كامل للأدمن، أو تحديث لحقل orderCount بس (بيتحصّل تلقائي عند
      // إرسال أي طلب حقيقي من عميل مش مسجّل دخول — شوف saveOrder في firestore.ts).
      allow update: if request.auth != null
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(["orderCount"]);
    }
    match /branches/{branchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /deliveryZones/{zoneId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /paymentMethods/{methodId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /suppliers/{supplierId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posterLinks/{linkId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // سجل الطلبات: أي زبون (من غير تسجيل دخول) يقدر يبعت طلب، لكن قراءة
    // السجل (بيانات عملاء) مقصورة على الأدمن بس — عكس باقي المجموعات فوق.
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    // النسخ الاحتياطي: مقصور على الأدمن بالكامل (قراءة وكتابة) — مفيش داعي
    // يكون عام زي باقي المجموعات، ومسار الـ cron بيسجّل دخول كأدمن قبل الكتابة.
    match /backups/{backupId} {
      allow read, write: if request.auth != null;
    }
    // اشتراكات إشعارات الخصومات: أي زبون (من غير تسجيل دخول) يقدر يسجّل
    // اشتراكه (زي orders)، لكن قراءتها (عشان إرسال الإشعارات) وحذفها مقصورة
    // على الأدمن بس.
    match /pushSubscriptions/{subId} {
      allow read, delete: if request.auth != null;
      allow create: if true;
    }
  }
}
